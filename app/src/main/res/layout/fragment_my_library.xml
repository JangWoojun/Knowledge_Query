<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    style="@style/BackgroundColor"
    android:id="@+id/root_view"
    android:scrollbars="none"
    tools:context=".main.MyLibraryFragment">

    <LinearLayout
        android:id="@+id/container"
        android:clickable="true"
        android:focusableInTouchMode="true"
        android:orientation="vertical"
        style="@style/BackgroundColor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:focusable="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_marginTop="30dp"
            android:layout_marginHorizontal="26dp"
            android:layout_width="match_parent"
            android:layout_height="55dp">

            <TextView
                style="@style/TextColor"
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_semibold"
                android:text="내 서재"
                android:textSize="24sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/search_button"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:gravity="center"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    style="@style/ImageColor"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/search_icon" />

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:visibility="gone"
                android:id="@+id/search_input_button"
                style="@style/SearchColor"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:outlineProvider="none"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/book_name_layout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/imageView2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="22dp"
                        android:src="@drawable/search_icon"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#C4C4C4" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/book_name_input"
                        style="@style/TextColor"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:background="@null"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="검색하기"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColorHighlight="@color/primary"
                        android:textColorHint="#C4C4C4"
                        android:textCursorDrawable="@drawable/custom_cursor"
                        android:textSelectHandle="@drawable/select_handler"
                        android:textSelectHandleLeft="@drawable/select_handler"
                        android:textSelectHandleRight="@drawable/select_handler"
                        android:textSize="16sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/imageView2"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>



        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.flexbox.FlexboxLayout
            android:layout_marginTop="20dp"
            android:id="@+id/category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:justifyContent="center"
            app:flexWrap="wrap">

            <LinearLayout
                android:layout_margin="8dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:id="@+id/my_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <androidx.cardview.widget.CardView
                    app:cardElevation="0dp"
                    app:cardCornerRadius="10dp"
                    android:id="@+id/my_button_background"
                    android:backgroundTint="@color/primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/my_button_text"
                            android:text="내 책"
                            android:textSize="14sp"
                            android:paddingVertical="10dp"
                            android:paddingHorizontal="26dp"
                            android:fontFamily="@font/poppins_regular"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:textColor="@color/white"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <LinearLayout
                android:layout_margin="8dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:id="@+id/bookmark_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <androidx.cardview.widget.CardView
                    app:cardElevation="0dp"
                    app:cardCornerRadius="10dp"
                    android:id="@+id/bookmark_button_background"
                    android:backgroundTint="@color/toggle_backgroundColor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/bookmark_button_text"
                        android:text="북마크"
                        android:textSize="14sp"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="26dp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_gravity="center"
                        android:gravity="center"
                        style="@style/TextColor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_margin="8dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:id="@+id/classic_novel_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <androidx.cardview.widget.CardView
                    app:cardElevation="0dp"
                    app:cardCornerRadius="10dp"
                    android:id="@+id/classic_novel_button_background"
                    android:backgroundTint="@color/toggle_backgroundColor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/classic_novel_button_text"
                        android:text="고전 소설"
                        android:textSize="14sp"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="26dp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_gravity="center"
                        android:gravity="center"
                        style="@style/TextColor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_margin="8dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:id="@+id/fairy_tale_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <androidx.cardview.widget.CardView
                    app:cardElevation="0dp"
                    app:cardCornerRadius="10dp"
                    android:id="@+id/fairy_tale_button_background"
                    android:backgroundTint="@color/toggle_backgroundColor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/fairy_tale_button_text"
                        android:text="전래 동화"
                        android:textSize="14sp"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="26dp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_gravity="center"
                        android:gravity="center"
                        style="@style/TextColor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_margin="8dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:id="@+id/poem_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <androidx.cardview.widget.CardView
                    app:cardElevation="0dp"
                    app:cardCornerRadius="10dp"
                    android:id="@+id/poem_button_background"
                    android:backgroundTint="@color/toggle_backgroundColor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/poem_button_text"
                        android:text="고전 시"
                        android:textSize="14sp"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="26dp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_gravity="center"
                        android:gravity="center"
                        style="@style/TextColor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_margin="8dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:id="@+id/social_news_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <androidx.cardview.widget.CardView
                    app:cardElevation="0dp"
                    app:cardCornerRadius="10dp"
                    android:id="@+id/social_news_button_background"
                    android:backgroundTint="@color/toggle_backgroundColor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/social_news_button_text"
                        android:text="사회 뉴스"
                        android:textSize="14sp"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="26dp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_gravity="center"
                        android:gravity="center"
                        style="@style/TextColor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_margin="8dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:id="@+id/it_news_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <androidx.cardview.widget.CardView
                    app:cardElevation="0dp"
                    app:cardCornerRadius="10dp"
                    android:id="@+id/it_news_button_background"
                    android:backgroundTint="@color/toggle_backgroundColor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/it_news_button_text"
                        android:text="IT 뉴스"
                        android:textSize="14sp"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="26dp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_gravity="center"
                        android:gravity="center"
                        style="@style/TextColor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_margin="8dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:id="@+id/daily_news_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <androidx.cardview.widget.CardView
                    app:cardElevation="0dp"
                    app:cardCornerRadius="10dp"
                    android:id="@+id/daily_news_button_background"
                    android:backgroundTint="@color/toggle_backgroundColor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/daily_news_button_text"
                        android:text="생활 뉴스"
                        android:textSize="14sp"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="26dp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_gravity="center"
                        android:gravity="center"
                        style="@style/TextColor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>


        </com.google.android.flexbox.FlexboxLayout>

        <RelativeLayout
            android:layout_marginBottom="50dp"
            android:layout_marginTop="30dp"
            android:id="@+id/relativeLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/book_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:nestedScrollingEnabled="false" />

        </RelativeLayout>

    </LinearLayout>

</ScrollView>
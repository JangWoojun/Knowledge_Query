<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout android:orientation="horizontal"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="15dp"
    android:layout_marginHorizontal="20dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.card.MaterialCardView
        android:background="@color/white"
        app:cardElevation="0dp"
        android:id="@+id/imageView"
        android:layout_width="40dp"
        android:layout_height="40dp"
        app:cardCornerRadius="45dp"
        app:layout_constraintBottom_toBottomOf="@+id/chat_background"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/chat_background">

        <com.airbnb.lottie.LottieAnimationView
            android:background="@color/white"
            android:id="@+id/lottieAnimationView"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            app:lottie_fileName="logo.json"
            app:lottie_url="@raw/logo" />


    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_marginStart="7dp"
        android:id="@+id/chat_background"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bot_chat_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/imageView"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/message"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="19.5dp"
            android:layout_marginVertical="18dp"
            android:fontFamily="@font/poppins_bold"
            android:text=""
            android:textSize="14sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/intro_navigation_graph"
    app:startDestination="@id/startFragment">

    <fragment
        android:id="@+id/startFragment"
        android:name="com.woojun.knowledge_query.StartFragment"
        android:label="fragment_start"
        tools:layout="@layout/fragment_start" >
        <action
            android:id="@+id/action_startFragment_to_modeChoiceFragment"
            app:destination="@id/modeChoiceFragment" />
    </fragment>
    <fragment
        android:id="@+id/modeChoiceFragment"
        android:name="com.woojun.knowledge_query.ModeChoiceFragment"
        android:label="fragment_mode_choice"
        tools:layout="@layout/fragment_mode_choice" />
</navigation>